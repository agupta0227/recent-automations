        private void LoadCSVData(string filePath) 
        {
            try
            {
                // Read and parse the CSV file into a list of SalesRecord objects (implementation omitted for brevity)
                List<SalesRecord> salesRecords = new List<SalesRecord>(); // Replace with actual logic
                using (StreamReader reader = new StreamReader(filePath))
                {
                    string line;
                    while ((line = reader.ReadLine()) != null) 
                    {
                        salesRecords.Add(DeserializeCSVLine(line));
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading data from {filePath}: {ex.Message}");
            }
        }

        private void SaveCSVData(List<SalesRecord> salesRecords, string filePath) 
        {
            try
            {
                // Write the list of SalesRecord objects to a CSV file (implementation omitted for brevity)
                using (StreamWriter writer = new StreamWriter(filePath))
                {
                    foreach (var record in salesRecords)
                    {
                        writer.WriteLine(SerializeCSVLine(record)); // Replace with actual logic 
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error saving data to {filePath}: {ex.Message}");
            }
        }

        private void ExportCSV(List<SalesRecord> salesRecords, string filePath) 
        {
            try
            {
                // Write the list of SalesRecord objects to a CSV file (implementation omitted for brevity)
